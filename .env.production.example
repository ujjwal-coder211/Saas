# Routely production environment template
# Copy to .env on your host — NEVER commit real secrets.

# --- Docker production (docker-compose.prod.yml) ---
POSTGRES_USER=aitotech
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=neuralrouter
ROUTELY_HTTP_PORT=8000
AKSH_HTTP_PORT=8000
JWT_SECRET=change-this-long-random-string

# --- App identity ---
NEURALROUTER_APP_NAME=Routely API
NEURALROUTER_APP_VERSION=0.1.0-routely
NEURALROUTER_ALLOW_UNAUTH=false

# --- Provider keys (OpenRouter only for free models) ---
OPENROUTER_API_KEY=
MOONSHOT_API_KEY=
DEEPINFRA_API_KEY=

# --- SaaS ---
DATABASE_URL=postgresql+psycopg2://USER:PASS@HOST:5432/neuralrouter
REDIS_URL=redis://HOST:6379/0
SAAS_ALLOW_PUBLIC_SIGNUP=false
SAAS_PUBLIC_URL=https://api.routely.aitotech.in

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# --- Billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# --- Sarva brain (Phase 2 — optional) ---
SARVA_INFERENCE_URL=
SARVA_BRAIN_MIN_EVAL_SCORE=0.75
SARVA_ADMIN_KEY=

# --- Search (optional) ---
AKSH_SEARCH_ENABLED=false
AKSH_SEARCH_API_KEY=
AKSH_SEARCH_PROVIDER=tavily
AKSH_SEARCH_MAX_RESULTS=5

# --- Vault (training — Phase 2) ---
SARVA_VAULT_HMAC_KEY=
SARVA_VAULT_ENCRYPTION_KEY=

# --- Website public demo ---
PUBLIC_DEMO_ENABLED=true
PUBLIC_DEMO_RATE_LIMIT=20
NEURALROUTER_RATE_LIMIT=60
NEURALROUTER_MAX_MESSAGE_CHARS=32000
NEURALROUTER_TIMEOUT_S=30
NEURALROUTER_MAX_RETRIES=2
NEURALROUTER_MAX_EXPERTS=1
NEURALROUTER_CORS_ORIGINS=https://app.routely.aitotech.in,https://aitotech.in
NEURALROUTER_MAX_CONCURRENT_PER_CLIENT=5
NEURALROUTER_MAX_GLOBAL_CONCURRENT=100

# --- Future index (Qdrant) ---
QDRANT_URL=
QDRANT_API_KEY=
