# Aksh production environment template
# Copy to .env on your host — NEVER commit real secrets.

# --- Docker production (docker-compose.prod.yml) ---
POSTGRES_USER=aitotech
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=neuralrouter
AKSH_HTTP_PORT=8000
JWT_SECRET=change-this-long-random-string

# --- App identity ---
NEURALROUTER_APP_NAME=Aksh API
NEURALROUTER_APP_VERSION=1.0.0-aksh
NEURALROUTER_ALLOW_UNAUTH=false

# --- Provider keys (required for chat) ---
OPENROUTER_API_KEY=
MOONSHOT_API_KEY=
DEEPINFRA_API_KEY=

# --- SaaS ---
DATABASE_URL=postgresql+psycopg2://USER:PASS@HOST:5432/neuralrouter
REDIS_URL=redis://HOST:6379/0
SAAS_ALLOW_PUBLIC_SIGNUP=false
SAAS_PUBLIC_URL=https://aksh.yourdomain.com

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# --- Billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# --- Omni brain ---
OMNI_INFERENCE_URL=
OMNI_BRAIN_MIN_EVAL_SCORE=0.75
OMNI_ADMIN_KEY=

# --- Aksh Search ---
AKSH_SEARCH_ENABLED=true
AKSH_SEARCH_API_KEY=
AKSH_SEARCH_PROVIDER=tavily
AKSH_SEARCH_MAX_RESULTS=5

# --- Vault (training) ---
OMNI_VAULT_HMAC_KEY=
OMNI_VAULT_ENCRYPTION_KEY=

# --- Website public demo (aitotech.in → /public/chat) ---
PUBLIC_DEMO_ENABLED=true
# Optional shared secret — set same value on Vercel as AGENTS_API_KEY
# AGENTS_API_KEY=
PUBLIC_DEMO_RATE_LIMIT=20
NEURALROUTER_RATE_LIMIT=60
NEURALROUTER_MAX_MESSAGE_CHARS=32000
NEURALROUTER_TIMEOUT_S=30
NEURALROUTER_MAX_RETRIES=2
NEURALROUTER_MAX_EXPERTS=3
NEURALROUTER_CORS_ORIGINS=https://aksh.yourdomain.com
NEURALROUTER_MAX_CONCURRENT_PER_CLIENT=5
NEURALROUTER_MAX_GLOBAL_CONCURRENT=100

# --- Future index (Qdrant) ---
QDRANT_URL=
QDRANT_API_KEY=
