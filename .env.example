# Provider API keys (never commit real values)
OPENROUTER_API_KEY=
MOONSHOT_API_KEY=
DEEPINFRA_API_KEY=

# Legacy single-tenant keys (optional if using DATABASE_URL SaaS keys)
NEURALROUTER_API_KEYS=

# Local dev only — allow requests without API key when no DB and no env keys
# NEURALROUTER_ALLOW_UNAUTH=true

# App identity
NEURALROUTER_APP_NAME=Routely API
NEURALROUTER_APP_VERSION=0.1.0-routely
NEURALROUTER_MAX_EXPERTS=1

# --- SaaS (PostgreSQL + Redis) ---
DATABASE_URL=postgresql+psycopg2://aitotech:aitotech_dev@localhost:5432/neuralrouter
REDIS_URL=redis://localhost:6379/0
SAAS_ALLOW_PUBLIC_SIGNUP=true
SAAS_PUBLIC_URL=http://localhost:8000

# Stripe billing (optional until Phase 2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# Clerk auth (production — optional for local MVP)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Sarva brain — versioned main controller (hot swap after training)
# After RunPod: serve_sarva.py → set this URL → plug_sarva_after_train.py --promote
SARVA_INFERENCE_URL=
SARVA_BRAIN_MIN_EVAL_SCORE=0.75
SARVA_ADMIN_KEY=
# Local wiring test without GPU: run serve with SARVA_INFERENCE_MOCK=1
# SARVA_INFERENCE_MOCK=1

# Aksh Search — Tavily/Serper/Brave
AKSH_SEARCH_ENABLED=true
AKSH_SEARCH_API_KEY=
AKSH_SEARCH_PROVIDER=tavily
AKSH_SEARCH_MAX_RESULTS=5

# Optional tuning
NEURALROUTER_RATE_LIMIT=60
NEURALROUTER_MAX_MESSAGE_CHARS=32000
NEURALROUTER_TIMEOUT_S=30
NEURALROUTER_MAX_RETRIES=2
NEURALROUTER_MAX_EXPERTS=3
NEURALROUTER_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
NEURALROUTER_MAX_CONCURRENT_PER_CLIENT=5
NEURALROUTER_MAX_GLOBAL_CONCURRENT=50

# Sarva Training Vault — PROTECT TRAINING DATA
# python -c "import secrets; print(secrets.token_hex(32))"
SARVA_VAULT_HMAC_KEY=
SARVA_VAULT_ENCRYPTION_KEY=

# Future codebase index (Qdrant — scaffold only)
QDRANT_URL=
QDRANT_API_KEY=

# Production template: see .env.production.example
